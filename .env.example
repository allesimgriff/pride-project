# Supabase
# Erstellen Sie ein Projekt unter https://supabase.com und tragen Sie die Werte ein.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: für Redirect nach Login (z. B. Production-URL)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# App URL (für Invite-Link in E-Mails)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# E-Mail Versand
# Empfehlung für Netlify: Resend (HTTP API) statt SMTP
EMAIL_PROVIDER=resend
EMAIL_FROM="PRIDE <noreply@allesimgriff.de>"
RESEND_API_KEY=your-resend-api-key

# SMTP (Fallback / lokal)
# SMTP_HOST=smtp.ionos.de
# SMTP_PORT=587
# SMTP_USER=your-ionos-email
# SMTP_PASS=your-ionos-password
# SMTP_FROM="PRIDE <noreply@allesimgriff.de>"
