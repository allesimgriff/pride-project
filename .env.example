# === Vorlage für .env.local (Keys nur in der Datei / im Dashboard, nie im Chat) ===
#
# So nutzen: In Cursor diese Datei öffnen → alles markieren → kopieren →
# neue Datei .env.local anlegen → einfügen → Werte aus Supabase (Project Settings → API) eintragen.
# Wenn .env.local schon existiert und die App läuft: nicht überschreiben.
#
# Supabase: https://supabase.com → dein Projekt → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Lokal: Port wie in LOKAL_STARTEN.md (üblich 3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Produkt-Edition (Build-Zeit): pride = volle UI, handwerker = reduzierte Oberfläche.
# Netlify: PRIDE-Site z. B. pride, Handwerker-Site: handwerker — beide bauen aus main.
# NEXT_PUBLIC_APP_EDITION=pride

# Optional: Redirect nach Login (z. B. Production-URL)
# NEXT_PUBLIC_SITE_URL=https://your-domain.netlify.app

# Optional: Speicher-Limit pro Workspace in Bytes (Standard: 5·10^9 ≈ 5 GB). Ab 75 % Nutzung erscheint ein Hinweis.
# WORKSPACE_STORAGE_LIMIT_BYTES=5000000000

# E-Mail Versand (optional – nur wenn die App E-Mails schicken soll, z. B. Einladungen)
# Ohne diese Zeilen: lokale Nutzung meist unkritisch; Versand schlägt dann fehl oder nutzt Fallback.
# Empfehlung für Netlify: Resend (HTTP API) statt SMTP
# EMAIL_PROVIDER=resend
# EMAIL_FROM="PRIDE <you@example.com>"
# RESEND_API_KEY=your-resend-api-key

# SMTP (Fallback / lokal)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-ionos-email
# SMTP_PASS=your-ionos-password
# SMTP_FROM="PRIDE <you@example.com>"
